<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Polskasoft Bonziworld</title>
    <style>
        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            font-family: Arial, sans-serif;
            background-color: #7b42bc;
            color: white;
            overflow: hidden;
        }

        .banner {
            width: 100%;
            height: 40px;
            background-color: #4a148c;
            position: absolute;
            top: 0;
            left: 0;
        }

        #loading-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #9c4fd3 0%, #7b42bc 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 999;
            cursor: pointer;
        }

        .loading-container {
            display: flex;
            width: 80%;
            max-width: 800px;
            align-items: center;
        }

        .left-side {
            flex: 1;
            text-align: right;
            padding-right: 40px;
            border-right: 1px solid rgba(255, 255, 255, 0.4);
        }

        .right-side {
            flex: 1;
            padding-left: 40px;
        }

        .logo-text {
            font-size: 1.5rem;
            margin: 0;
            opacity: 0.9;
        }

        .main-title {
            font-size: 4rem;
            font-weight: bold;
            margin: -10px 0 0 0;
            line-height: 1;
        }

        .orange-text {
            color: #ff6600;
        }

        .loading-text {
            font-size: 2.5rem;
            font-style: italic;
            font-weight: bold;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
            animation: blink 1.5s infinite;
        }

        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.4; }
        }

        #desktop {
            display: none;
            width: 100%;
            height: 100%;
            position: relative;
            box-sizing: border-box;
            padding-top: 50px;
        }

        #bonzi {
            position: absolute;
            bottom: 140px;
            left: 50%;
            transform: translateX(-50%);
            text-align: center;
        }

        /* Sprite Sheet Setup */
        .bonzi-sprite {
            width: 64px;               
            height: 64px;              
            /* Default fallback sprite */
            background-image: url('997346af-0201-46f7-96d2-4fa7fae64cbc_2.jpg'); 
            background-repeat: no-repeat;
            display: inline-block;
            image-rendering: pixelated; 
            transform: scale(2);       
            transform-origin: bottom center;
            animation: bonzi-idle 1.2s steps(4) infinite;
        }

        @keyframes bonzi-idle {
            from { background-position: 0px 0px; }
            to { background-position: -256px 0px; } 
        }

        .bubble {
            background: white;
            color: black;
            border-radius: 10px;
            padding: 10px 15px;
            position: relative;
            margin-bottom: 30px;
            max-width: 250px;
            word-wrap: break-word;
            box-shadow: 3px 3px 10px rgba(0,0,0,0.2);
            display: none;
        }

        .bubble::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 50%;
            transform: translateX(-50%);
            border-width: 10px 10px 0;
            border-style: solid;
            border-color: white transparent;
            display: block;
            width: 0;
        }

        .chat-bar {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            background-color: #4a148c;
            padding: 15px;
            display: flex;
            justify-content: center;
            gap: 10px;
            box-sizing: border-box;
        }

        .chat-bar input {
            width: 50%;
            max-width: 500px;
            padding: 10px;
            border: none;
            border-radius: 4px;
            font-size: 1rem;
            outline: none;
        }

        .chat-bar select {
            padding: 10px;
            border-radius: 4px;
            border: none;
            background-color: white;
            color: black;
            font-weight: bold;
            cursor: pointer;
        }
    </style>
</head>
<body>

    <div class="banner"></div>

    <div id="loading-screen" onclick="enterWorld()">
        <div class="loading-container">
            <div class="left-side">
                <p class="logo-text">Polskasoft</p>
                <h1 class="main-title">Bonzi<span class="orange-text">world</span></h1>
            </div>
            <div class="right-side">
                <div class="loading-text">loading</div>
            </div>
        </div>
    </div>

    <div id="desktop">
        <div id="bonzi">
            <div class="bubble" id="speech-bubble">Hello!</div>
            <div class="bonzi-sprite" id="bonzi-character"></div>
        </div>

        <div class="chat-bar">
            <!-- Dropdown to select different images dynamically -->
            <select id="skin-select" onchange="changeSkin()">
                <option value="997346af-0201-46f7-96d2-4fa7fae64cbc_2.jpg">Purple (Hammer)</option>
                <option value="c2cbc517-7f8b-45f7-8752-5500adca6efb_2.jpg">Purple (Trollface)</option>
                <option value="0a50c556-365b-455b-8879-013c24646257_2.jpg">Green / Beard</option>
                <option value="4d7dfaea-6184-43e5-95c9-66912fc4288f_2.jpg">Brown (Classic)</option>
                <option value="865aee2c-8830-477e-ae08-fab6ec0b77f9_2.jpg">Purple (Cape)</option>
                <option value="24ec2c0d-99e2-4bad-821c-a0f6b581cf58_2.jpg">Lime Green</option>
                <option value="bf16537b-e78b-47ba-b155-b8ccedcced59_2.jpg">Purple (Beard)</option>
                <option value="de1afe89-525a-41a4-853b-a10d85c20a1b_2.jpg">Green (Custom Heads)</option>
                <option value="pope_2.jpg">Pope</option>
                <option value="king_2.jpg">King</option>
            </select>
            <input type="text" id="chat-input" placeholder="Type here and press Enter..." autofocus>
        </div>
    </div>

    <script>
        window.addEventListener('keydown', function(event) {
            if (event.key === 'Enter' && document.getElementById('loading-screen').style.display !== 'none') {
                enterWorld();
            }
        });

        function enterWorld() {
            document.getElementById('loading-screen').style.display = 'none';
            document.getElementById('desktop').style.display = 'block';
            document.getElementById('chat-input').focus();
            bonziSpeak("Welcome to my website!");
        }

        function changeSkin() {
            const select = document.getElementById('skin-select');
            const character = document.getElementById('bonzi-character');
            character.style.backgroundImage = "url('" + select.value + "')";
        }

        function bonziSpeak(text) {
            if (!text.trim()) return;
            const bubble = document.getElementById('speech-bubble');
            bubble.innerText = text;
            bubble.style.display = 'block';

            const utterance = new SpeechSynthesisUtterance(text);
            utterance.pitch = 1.3; 
            window.speechSynthesis.speak(utterance);
        }

        document.getElementById('chat-input').addEventListener('keydown', function(event) {
            if (event.key === 'Enter') {
                bonziSpeak(this.value);
                this.value = '';
            }
        });
    </script>
</body>
</html>
