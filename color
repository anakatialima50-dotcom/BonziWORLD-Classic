<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GitHub BonziWorld Tribute</title>
    <style>
        /* Custom Theme Colors for your site */
        :root {
            --main-bg: #1c2e24;       /* Dark forest/matrix green theme background */
            --gradient-light: #2d4a3a;/* Lighter green flare for background gradient */
            --top-banner: #0f1a14;    /* Dark banner bar at the top */
            --accent-orange: #ff9900; /* The orange "world" text color */
            --chat-bar-bg: #0b120e;   /* Dark input bar background */
            --text-color: #ffffff;    /* Text color */
        }

        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--main-bg);
            color: var(--text-color);
            overflow: hidden;
        }

        /* Top dark banner */
        .banner {
            width: 100%;
            height: 40px;
            background-color: var(--top-banner);
            position: absolute;
            top: 0;
            left: 0;
        }

        /* Loading Screen matching Captura de tela 2026-06-29 101240.png */
        #loading-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, var(--gradient-light) 0%, var(--main-bg) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 999;
            cursor: pointer;
        }

        .loading-container {
            display: flex;
            width: 80%;
            max-width: 800px;
            align-items: center;
        }

        .left-side {
            flex: 1;
            text-align: right;
            padding-right: 40px;
            border-right: 1px solid rgba(255, 255, 255, 0.4);
        }

        .right-side {
            flex: 1;
            padding-left: 40px;
        }

        .logo-text {
            font-size: 1.5rem;
            margin: 0;
            opacity: 0.9;
        }

        .main-title {
            font-size: 4rem;
            font-weight: bold;
            margin: -10px 0 0 0;
            line-height: 1;
        }

        .orange-text {
            color: var(--accent-orange);
        }

        .loading-text {
            font-size: 2.5rem;
            font-style: italic;
            font-weight: bold;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
            animation: blink 1.5s infinite;
        }

        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.4; }
        }

        /* Main Desktop Area */
        #desktop {
            display: none;
            width: 100%;
            height: 100%;
            position: relative;
            box-sizing: border-box;
            padding-top: 50px;
        }

        #bonzi {
            position: absolute;
            bottom: 140px;
            left: 50%;
            transform: translateX(-50%);
            text-align: center;
        }

        /* Custom Sprite Sheet Frame Configuration */
        .bonzi-custom-sprite {
            width: 64px;               /* Width of individual sprite frame */
            height: 64px;              /* Height of individual sprite frame */
            background-image: url('watermarked_img_4486413155029112578.png');
            background-repeat: no-repeat;
            display: inline-block;
            image-rendering: pixelated; /* Keeps pixel art perfectly crisp */
            transform: scale(2);       /* Doubles the size so it's easier to see on screen */
            transform-origin: bottom center;
            
            /* Loops through the first 4 idle frames of your sheet */
            animation: bonzi-idle 1.2s steps(4) infinite;
        }

        @keyframes bonzi-idle {
            from { background-position: 0px 0px; }
            to { background-position: -256px 0px; } /* 64px * 4 frames = 256px horizontal shift */
        }

        /* Text Speech Bubble */
        .bubble {
            background: white;
            color: black;
            border-radius: 10px;
            padding: 10px 15px;
            position: relative;
            margin-bottom: 30px;
            max-width: 250px;
            word-wrap: break-word;
            box-shadow: 3px 3px 10px rgba(0,0,0,0.2);
            display: none;
        }

        .bubble::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 50%;
            transform: translateX(-50%);
            border-width: 10px 10px 0;
            border-style: solid;
            border-color: white transparent;
            display: block;
            width: 0;
        }

        /* Bottom Chat Bar */
        .chat-bar {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            background-color: var(--chat-bar-bg);
            padding: 15px;
            display: flex;
            justify-content: center;
            box-sizing: border-box;
        }

        .chat-bar input {
            width: 60%;
            max-width: 600px;
            padding: 10px;
            border: none;
            border-radius: 4px;
            font-size: 1rem;
            outline: none;
            background-color: #1e2923;
            color: #ffffff;
            border: 1px solid #344a3e;
        }
    </style>
</head>
<body>

    <div class="banner"></div>

    <!-- Loading Screen (Bypassed on Enter key) -->
    <div id="loading-screen" onclick="enterWorld()">
        <div class="loading-container">
            <div class="left-side">
                <p class="logo-text">Polskasoft</p>
                <h1 class="main-title">Bonzi<span class="orange-text">world</span></h1>
            </div>
            <div class="right-side">
                <div class="loading-text">loading</div>
            </div>
        </div>
    </div>

    <!-- Active App Space -->
    <div id="desktop">
        <div id="bonzi">
            <div class="bubble" id="speech-bubble">Hello World!</div>
            <!-- Div that uses your custom sprite image background -->
            <div class="bonzi-custom-sprite"></div>
        </div>

        <div class="chat-bar">
            <input type="text" id="chat-input" placeholder="Type here and press Enter..." autofocus>
        </div>
    </div>

    <script>
        // Trigger login transition on Enter key
        window.addEventListener('keydown', function(event) {
            if (event.key === 'Enter' && document.getElementById('loading-screen').style.display !== 'none') {
                enterWorld();
            }
        });

        function enterWorld() {
            document.getElementById('loading-screen').style.display = 'none';
            document.getElementById('desktop').style.display = 'block';
            document.getElementById('chat-input').focus();
            bonziSpeak("Welcome to my room!");
        }

        // Handles Text Speech Engine
        function bonziSpeak(text) {
            if (!text.trim()) return;
            const bubble = document.getElementById('speech-bubble');
            bubble.innerText = text;
            bubble.style.display = 'block';

            const utterance = new SpeechSynthesisUtterance(text);
            utterance.pitch = 1.3; 
            window.speechSynthesis.speak(utterance);
        }

        // Monitors chat submission
        document.getElementById('chat-input').addEventListener('keydown', function(event) {
            if (event.key === 'Enter') {
                bonziSpeak(this.value);
                this.value = '';
            }
        });
    </script>
</body>
</html>
